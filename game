<!DOCTYPE html>
<html>
<head>
  <title>hey daddy clicker</title>
  <style>
    body {
      background: #c2b49a;
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 10px;
    }

    h1 {
      font-size: 28px;
      text-align: center;
      color: #111;
      margin: 5px 0 0 0;
      text-decoration: underline;
    }

    #counter {
      text-align: center;
      font-size: 22px;
      margin: 8px 0;
      color: #111;
    }

    #per-sec {
      text-align: center;
      font-size: 14px;
      color: #444;
      margin-bottom: 6px;
    }

    #main {
      display: flex;
      gap: 10px;
      justify-content: center;
      align-items: flex-start;
      flex-wrap: wrap;
    }

    #clicker-area {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    #daddy {
      width: 180px;
      cursor: pointer;
      border: 3px solid #333;
      display: block;
      image-rendering: pixelated;
    }

    #daddy:active {
      margin-top: 3px;
      margin-bottom: -3px;
    }

    #click-label {
      font-size: 13px;
      color: #222;
      margin-top: 4px;
    }

    #upgrades {
      background: #e8dcc8;
      border: 2px solid #555;
      padding: 8px;
      width: 260px;
    }

    #upgrades h2 {
      font-size: 16px;
      margin: 0 0 6px 0;
      border-bottom: 1px solid #888;
      padding-bottom: 4px;
    }

    .upgrade-btn {
      display: block;
      width: 100%;
      background: #d4c4a0;
      border: 2px solid #666;
      padding: 6px 8px;
      margin-bottom: 6px;
      cursor: pointer;
      text-align: left;
      font-size: 13px;
      box-sizing: border-box;
    }

    .upgrade-btn:disabled {
      background: #bbb;
      color: #888;
      cursor: default;
      border-color: #999;
    }

    .upgrade-btn .upg-name {
      font-weight: bold;
      display: block;
    }

    .upgrade-btn .upg-desc {
      font-size: 11px;
      color: #555;
    }

    .upgrade-btn .upg-cost {
      font-size: 12px;
      color: #222;
    }

    #stats {
      background: #e8dcc8;
      border: 2px solid #555;
      padding: 8px;
      width: 150px;
      font-size: 13px;
    }

    #stats h2 {
      font-size: 16px;
      margin: 0 0 6px 0;
      border-bottom: 1px solid #888;
      padding-bottom: 4px;
    }

    #stats p {
      margin: 3px 0;
    }

    #audio-btn {
      display: block;
      margin: 8px auto 0 auto;
      padding: 4px 12px;
      font-size: 13px;
      cursor: pointer;
      background: #d4c4a0;
      border: 2px solid #666;
    }
  </style>
</head>
<body>

<h1>hey daddy clicker</h1>
<div id="counter">0 daddies</div>
<div id="per-sec">0 per second</div>

<div id="main">

  <div id="stats">
    <h2>stats</h2>
    <p>total clicks: <span id="stat-clicks">0</span></p>
    <p>total earned: <span id="stat-total">0</span></p>
    <p id="stat-upgrades-owned">upgrades: 0</p>
  </div>

  <div id="clicker-area">
    <img id="daddy" src="https://raw.githubusercontent.com/messenger-co/hey-daddy-clicker/main/image.png" alt="daddy" />
    <span id="click-label">click daddy</span>
    <button id="audio-btn" onclick="toggleAudio()">▶ play music</button>
  </div>

  <div id="upgrades">
    <h2>upgrades</h2>
    <div id="upgrade-list"></div>
  </div>

</div>

<audio id="bgm" loop>
  <source src="https://raw.githubusercontent.com/messenger-co/hey-daddy-clicker/main/tam.mp4" type="video/mp4">
</audio>

<script>
  var cookies = 0;
  var totalEarned = 0;
  var totalClicks = 0;
  var clickPower = 1;
  var perSecond = 0;
  var audioPlaying = false;

  var upgrades = [
    { id: 0, name: "better finger",      desc: "+1 per click",         cost: 10,    bought: 0, type: "click",  value: 1 },
    { id: 1, name: "grandma",            desc: "+0.1 per second",      cost: 50,    bought: 0, type: "auto",   value: 0.1 },
    { id: 2, name: "strong finger",      desc: "+3 per click",         cost: 100,   bought: 0, type: "click",  value: 3 },
    { id: 3, name: "a dog",              desc: "+0.5 per second",      cost: 250,   bought: 0, type: "auto",   value: 0.5 },
    { id: 4, name: "robot hand",         desc: "+5 per click",         cost: 500,   bought: 0, type: "click",  value: 5 },
    { id: 5, name: "a whole farm",       desc: "+2 per second",        cost: 1000,  bought: 0, type: "auto",   value: 2 },
    { id: 6, name: "laser finger",       desc: "+15 per click",        cost: 2500,  bought: 0, type: "click",  value: 15 },
    { id: 7, name: "daddy factory",      desc: "+10 per second",       cost: 5000,  bought: 0, type: "auto",   value: 10 },
    { id: 8, name: "the dad dimension",  desc: "+50 per click",        cost: 10000, bought: 0, type: "click",  value: 50 },
    { id: 9, name: "infinite daddies",   desc: "+50 per second",       cost: 25000, bought: 0, type: "auto",   value: 50 },
  ];

  function renderUpgrades() {
    var list = document.getElementById("upgrade-list");
    list.innerHTML = "";
    for (var i = 0; i < upgrades.length; i++) {
      var u = upgrades[i];
      var btn = document.createElement("button");
      btn.className = "upgrade-btn";
      var costNow = Math.floor(u.cost * Math.pow(1.15, u.bought));
      btn.innerHTML =
        '<span class="upg-name">' + u.name + (u.bought > 0 ? ' (x' + u.bought + ')' : '') + '</span>' +
        '<span class="upg-desc">' + u.desc + '</span>' +
        '<span class="upg-cost">cost: ' + costNow + '</span>';
      btn.disabled = cookies < costNow;
      btn.setAttribute("data-id", i);
      btn.onclick = function() {
        buyUpgrade(parseInt(this.getAttribute("data-id")));
      };
      list.appendChild(btn);
    }
  }

  function buyUpgrade(id) {
    var u = upgrades[id];
    var costNow = Math.floor(u.cost * Math.pow(1.15, u.bought));
    if (cookies >= costNow) {
      cookies -= costNow;
      u.bought++;
      if (u.type === "click") {
        clickPower += u.value;
      } else {
        perSecond += u.value;
      }
      updateDisplay();
      renderUpgrades();
      updateStats();
    }
  }

  document.getElementById("daddy").onclick = function() {
    cookies += clickPower;
    totalEarned += clickPower;
    totalClicks++;
    updateDisplay();
    renderUpgrades();
    updateStats();
  };

  function updateDisplay() {
    document.getElementById("counter").textContent = Math.floor(cookies) + " daddies";
    document.getElementById("per-sec").textContent = perSecond.toFixed(1) + " per second";
  }

  function updateStats() {
    document.getElementById("stat-clicks").textContent = totalClicks;
    document.getElementById("stat-total").textContent = Math.floor(totalEarned);
    var owned = 0;
    for (var i = 0; i < upgrades.length; i++) owned += upgrades[i].bought;
    document.getElementById("stat-upgrades-owned").textContent = "upgrades: " + owned;
  }

  function toggleAudio() {
    var audio = document.getElementById("bgm");
    var btn = document.getElementById("audio-btn");
    if (audioPlaying) {
      audio.pause();
      btn.textContent = "▶ play music";
      audioPlaying = false;
    } else {
      audio.play();
      btn.textContent = "⏸ pause music";
      audioPlaying = true;
    }
  }

  setInterval(function() {
    if (perSecond > 0) {
      var gain = perSecond / 20;
      cookies += gain;
      totalEarned += gain;
      updateDisplay();
      renderUpgrades();
    }
  }, 50);

  renderUpgrades();
</script>

</body>
</html>
